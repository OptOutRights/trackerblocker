{
  "name": "trackerblocker",
  "version": "0.1.0",
  "description": "A Firefox-first WebExtension that blocks and explains likely third-party trackers.",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:firefox": "wxt -b firefox",
    "build:firefox": "wxt build -b firefox",
    "zip:firefox": "wxt zip -b firefox",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:easyprivacy:coverage": "vitest run scripts/easyprivacy/coverage.test.ts --reporter=verbose",
    "test:easyprivacy:firefox": "npm run build:firefox && node scripts/easyprivacy/firefox-integration.mjs",
    "test:easyprivacy:firefox:degraded": "npm run build:firefox && node scripts/easyprivacy/firefox-degraded.mjs",
    "test:easyprivacy:firefox:permission": "npm run build:firefox && node scripts/easyprivacy/firefox-permission.mjs",
    "test:easyprivacy:firefox:off": "WXT_EASYPRIVACY_MATCHING=false wxt build -b firefox && EASYPRIVACY_EXPECT_MATCHING=false node scripts/easyprivacy/firefox-integration.mjs",
    "test:easyprivacy:performance": "node scripts/easyprivacy/firefox-performance.mjs",
    "test:easyprivacy:package": "node scripts/easyprivacy/package-evidence.mjs",
    "test:easyprivacy:offline": "node scripts/easyprivacy/offline-evidence.mjs",
    "test:easyprivacy": "npm run verify:easyprivacy && npm test && npm run typecheck && npm run test:easyprivacy:offline && npm run test:easyprivacy:performance && npm run test:easyprivacy:firefox && npm run test:easyprivacy:firefox:degraded && npm run test:easyprivacy:firefox:permission && npm run test:easyprivacy:firefox:off && npm run test:easyprivacy:package && npm run lint:firefox",
    "generate:easyprivacy": "node scripts/easyprivacy/generate.mjs",
    "update:easyprivacy": "node scripts/easyprivacy/update.mjs",
    "verify:easyprivacy": "node scripts/easyprivacy/verify.mjs",
    "lint:firefox": "npm run build:firefox && web-ext lint --source-dir .output/firefox-mv3",
    "web-ext:firefox": "web-ext run --source-dir .output/firefox-mv3",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@fontsource-variable/outfit": "5.3.0",
    "@ghostery/adblocker": "2.18.1",
    "preact": "^10.29.4",
    "tldts": "^7.4.6"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/vite": "^4.3.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "web-ext": "^10.4.0",
    "wxt": "^0.20.27"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "shell-quote": "^1.8.4",
    "tmp": "^0.2.7",
    "uuid": "^11.1.1"
  }
}
